[alias]
	branches = for-each-ref --sort=-committerdate refs/heads/
	co = checkout
	hist = log --graph --color=always --pretty='[%C(cyan)%h%Creset]%C(bold cyan)%d%Creset %s' --all
	pu = !git push origin `git branch --show-current`
	puf = !git push origin `git branch --show-current` --force-with-lease
	puff = !git push origin `git branch --show-current` --force
	s = status -uno
	shelve = !git add . && git stash
	u = !git add . && git stash && git fetch --prune --prune-tags && git pull --rebase && git stash pop
	update = !git u

[color]
	ui = auto

[core]
	autocrlf = input
	editor = vim
	attributesfile = ~/.gitattributes
	excludesfile = ~/.gitexclude
	fsmonitor = true
	untrackedcache = true

[fetch]
	prune = true

[filter "lfs"]
	clean = git lfs clean %f
	smudge = git lfs smudge %f
	required = true

[include]
    path = ~/.gitconfig.custom 

[init]
	defaultBranch = main

[push]
	default = current

[remote "origin"]
	prune = true

[url "ssh://git@github.com/lackerman"]
	insteadOf = https://github.com/lackerman
